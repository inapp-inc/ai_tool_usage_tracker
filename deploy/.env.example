# Production deployment — copied to .env by deploy-docker.sh if missing.
# Do not commit .env with real secrets.

POSTGRES_USER=aitracker
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=aitracker
POSTGRES_PORT=5433

ENVIRONMENT=production

# Bootstrap super admin (created on first startup; credentials synced on redeploy)
SEED_SUPER_ADMIN_ON_STARTUP=true
SEED_SUPER_ADMIN_SYNC_CREDENTIALS=true
SUPER_ADMIN_EMAIL=admin@foundry.inapp.com
SUPER_ADMIN_PASSWORD=123456789

# Single published port — host nginx proxies /aitool/ here (SPA + API gateway)
APP_PORT=4501
FRONTEND_PORT=4501

# Public URL paths (API proxied inside frontend container to api:8000)
VITE_BASE_PATH=/aitool/
VITE_API_BASE_URL=/aitool/api/v1

CORS_ORIGINS=https://foundry.inapp.com,http://foundry.inapp.com

# DATABASE_URL is written by deploy-docker.sh — must match POSTGRES_PASSWORD.

JWT_SECRET_KEY=change_me_jwt_secret_production
COLLECTOR_ENCRYPTION_KEY=change_me_collector_encryption_key_production
COLLECTOR_SCHEDULER_ENABLED=true

# Legacy aliases still supported: DEV_SUPER_ADMIN_EMAIL / DEV_SUPER_ADMIN_PASSWORD
