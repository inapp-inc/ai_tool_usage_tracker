# Local dev (npm run dev): leave VITE_API_BASE_URL unset — Vite proxies /api/v1 to the backend.
# Or set an explicit URL when running the frontend outside Docker:
# VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
# On Windows prefer 127.0.0.1 over localhost (IPv6 ::1 can hit wslrelay instead of Docker).
