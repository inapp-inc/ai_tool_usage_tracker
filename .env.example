# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=aitracker
POSTGRES_PASSWORD=aitracker
POSTGRES_DB=aitracker

# ── Redis ─────────────────────────────────────────────────────────────────────
# Inside Docker the hostname is "redis" (the service name).
# For local bare-metal dev change to localhost.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_jwt_secret_dev_only
CREDENTIAL_ENCRYPTION_KEY=change_me_32_byte_encryption_key_dev

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development

POSTGRES_USER=tokentracker

POSTGRES_PASSWORD=tokentracker

POSTGRES_DB=tokentracker

APP_SECRET_KEY=change-me-in-production

APP_ENV=production

APP_LOG_LEVEL=INFO

FRONTEND_URL=https://foundry.inapp.com/aitool

VITE_BASE_PATH=/aitool

BACKEND_PORT=4500

APP_PORT=4501

# ── Frontend (Docker production build) ────────────────────────────────────────
VITE_API_BASE_URL=/aitool/api/v1
VITE_BASE_PATH=/aitool

# ── Dev credentials (seed_dev_admin.py) ───────────────────────────────────────
DEV_SUPER_ADMIN_EMAIL=admin@acme.example
DEV_SUPER_ADMIN_PASSWORD=SecurePass123!
