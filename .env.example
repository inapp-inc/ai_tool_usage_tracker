# Copy to .env and adjust values for local development.
# Do not commit .env — production secrets belong in a secrets manager (NFR-SEC-008).
# Production deploy: use deploy/.env.example and scripts/deploy-docker.sh

# PostgreSQL (Docker service: postgres)
POSTGRES_USER=aitracker
POSTGRES_PASSWORD=change_me_dev_only
POSTGRES_DB=aitracker
POSTGRES_PORT=5433

# Application (local development)
ENVIRONMENT=development
API_PORT=8000
FRONTEND_PORT=4501

# CORS — local dev (Vite on :5173)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000

# Database URL — use Docker Compose service hostname inside containers.
DATABASE_URL=postgresql+asyncpg://aitracker:change_me_dev_only@postgres:5432/aitracker

# Token collector (runs inside API container)
COLLECTOR_SCHEDULER_ENABLED=true
COLLECTOR_ENCRYPTION_KEY=change_me_collector_encryption_key_dev

# JWT auth
JWT_SECRET_KEY=change_me_jwt_secret_dev_only
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Dev Super Admin (seeded on first startup when auth tables are empty)
DEV_SUPER_ADMIN_EMAIL=admin@example.com
DEV_SUPER_ADMIN_PASSWORD=change_me_dev_only
