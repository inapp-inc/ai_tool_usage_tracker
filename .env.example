# Copy to .env and adjust values for local development.
# Do not commit .env — production secrets belong in a secrets manager (NFR-SEC-008).

# PostgreSQL (Docker service: postgres)
POSTGRES_USER=aitracker
POSTGRES_PASSWORD=change_me_dev_only
POSTGRES_DB=aitracker
POSTGRES_PORT=5432

# Redis (Docker service: redis)
REDIS_PORT=6379

# Application
ENVIRONMENT=development
API_PORT=8000
FRONTEND_PORT=5173

# Application URLs — use Docker Compose service hostnames inside containers.
DATABASE_URL=postgresql+asyncpg://aitracker:change_me_dev_only@postgres:5432/aitracker
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Local object storage (Docker volume — not S3)
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=/var/lib/ai-tracker/storage
LOCAL_STORAGE_UPLOADS_DIR=uploads
LOCAL_STORAGE_REPORTS_DIR=reports
LOCAL_BACKUP_ROOT=/backups

# JWT and encryption keys (TASK-INF-002+) — placeholders only, not production values
JWT_SECRET_KEY=change_me_jwt_secret_dev_only
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_SECRET_KEY=change_me_jwt_refresh_secret_dev_only
CREDENTIAL_ENCRYPTION_KEY=change_me_32_byte_encryption_key_dev
